<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="100%" style="stop-color:#16213e"/>
    </linearGradient>
  </defs>
  <rect width="32" height="32" rx="6" fill="url(#bg)"/>
  <!-- Neural connections -->
  <line x1="8" y1="8" x2="16" y2="16" stroke="#4a9eff" stroke-width="1.2" opacity="0.6"/>
  <line x1="24" y1="8" x2="16" y2="16" stroke="#4a9eff" stroke-width="1.2" opacity="0.6"/>
  <line x1="16" y1="16" x2="8" y2="24" stroke="#4a9eff" stroke-width="1.2" opacity="0.6"/>
  <line x1="16" y1="16" x2="24" y2="24" stroke="#4a9eff" stroke-width="1.2" opacity="0.6"/>
  <line x1="16" y1="16" x2="16" y2="6" stroke="#4a9eff" stroke-width="1.2" opacity="0.4"/>
  <line x1="16" y1="16" x2="16" y2="26" stroke="#4a9eff" stroke-width="1.2" opacity="0.4"/>
  <!-- Nodes -->
  <circle cx="8" cy="8" r="2.5" fill="#4a9eff" opacity="0.8"/>
  <circle cx="24" cy="8" r="2.5" fill="#4a9eff" opacity="0.8"/>
  <circle cx="8" cy="24" r="2.5" fill="#4a9eff" opacity="0.8"/>
  <circle cx="24" cy="24" r="2.5" fill="#4a9eff" opacity="0.8"/>
  <circle cx="16" cy="6" r="2" fill="#4a9eff" opacity="0.5"/>
  <circle cx="16" cy="26" r="2" fill="#4a9eff" opacity="0.5"/>
  <!-- Center node (curiosity spark) -->
  <circle cx="16" cy="16" r="4" fill="#ffd700"/>
  <circle cx="16" cy="16" r="2.5" fill="#fff" opacity="0.9"/>
</svg>
